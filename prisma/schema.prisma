generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

enum TruckType {
  CDE
  CDD
  FUSO
  TRONTON
  WINGBOX
  TRAILER
}

enum FuelType {
  BIOSOLAR
  DEXLITE
  PERTAMINA_DEX
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
}

enum TollCategory {
  GOL_1
  GOL_2
  GOL_3
  GOL_4
  GOL_5
}

enum ManifestStatus {
  PENDING
  EN_ROUTE
  COMPLETED
}

model Tenant {
  id   String @id @default(cuid())
  name String
  slug String @unique

  users   User[]
  tolls   Toll[]
  trucks  Truck[]
  routes  Route[]
  drivers Driver[]
  manifests Manifest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  fullName String @map("full_name")
  role     Role   @default(STAFF)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

model Toll {
  id       String       @id @default(cuid())
  name     String
  category TollCategory
  fee      Decimal      @db.Decimal(12, 2)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  routes Route[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("tolls")
}

model Truck {
  id              String    @id @default(cuid())
  licensePlate    String    @unique @map("license_plate")
  type            TruckType
  fuelType        FuelType  @map("fuel_type")
  fuelRatio       Float     @map("fuel_ratio") // KM/Liter
  currentOdometer Float     @map("current_odometer")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  manifests Manifest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("trucks")
}

model Route {
  id             String @id @default(cuid())
  origin         String
  destination    String
  baseDistanceKm Float  @map("base_distance_km")

  tolls Toll[]

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  manifests Manifest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("routes")
}

model Driver {
  id             String       @id @default(cuid())
  fullName       String       @map("full_name")
  phoneNumber    String       @map("phone_number")
  licenseNumber  String       @map("license_number")
  status         DriverStatus @default(AVAILABLE)
  dailyAllowance Decimal      @map("daily_allowance") @db.Decimal(12, 2)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  manifests Manifest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("drivers")
}

model Manifest {
  id                   String         @id @default(cuid())
  manifestNumber       String         @unique @map("manifest_number")
  status               ManifestStatus @default(PENDING)

  truckId              String         @map("truck_id")
  truck                Truck          @relation(fields: [truckId], references: [id])

  driverId             String         @map("driver_id")
  driver               Driver         @relation(fields: [driverId], references: [id])

  routeId              String         @map("route_id")
  route                Route          @relation(fields: [routeId], references: [id])

  additionalDistanceKm Float          @default(0) @map("additional_distance_km")
  totalEstimatedCost   Decimal        @db.Decimal(12, 2) @map("total_estimated_cost")
  departureDate        DateTime       @map("departure_date")

  tenantId             String         @map("tenant_id")
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([tenantId])
  @@map("manifests")
}
